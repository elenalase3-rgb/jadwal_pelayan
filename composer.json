{
  "name": "codeigniter4/appstarter",
  "description": "CodeIgniter4 starter app",
  "license": "MIT",
  "type": "project",

  "require": {
      "php": "^8.2",
      "codeigniter4/framework": "^4.7",
      "phpoffice/phpspreadsheet": "*"
  },

  "autoload": {
      "psr-4": {
          "App\\": "app/",
          "Config\\": "app/Config/"
      }
  },

  "config": {
      "optimize-autoloader": true,
      "preferred-install": "dist",
      "sort-packages": true
  }
}